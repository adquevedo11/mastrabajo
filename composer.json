{
    "name": "organizador/cedulas-pdf",
    "description": "Organizador de Cédulas PDF - Aplicación web para consolidar PDFs según listado Excel",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "setasign/fpdi": "^2.3",
        "setasign/fpdf": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
